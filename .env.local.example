# EmailJS credentials (https://www.emailjs.com)
# 1. Create a free account and an email service + template.
# 2. Copy the IDs/key below, then rename this file to ".env.local".
# 3. Restart the dev server after changing these.
#
# Your EmailJS template should include the variables:
#   {{from_name}}, {{from_email}}, {{company}}, {{message}}

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
